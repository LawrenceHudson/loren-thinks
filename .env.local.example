# ---------------------------------------------------------------------------
# Loren.thinks environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your Sanity project values.
#
#   cp .env.local.example .env.local
#
# IMPORTANT: The site runs fully WITHOUT these variables. If no project ID is
# set, bundled sample content is served so `npm run dev` shows the full design
# immediately. Set these only when you are ready to connect a real Sanity CMS.
#
# NOTE: The Sanity CLI (used for seeding) does NOT read this file. See the
# README "Seeding starter content" section — you must export the project ID in
# your shell before running `npx sanity dataset import`.
# ---------------------------------------------------------------------------

# Your Sanity project ID (from https://www.sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset name — keep as "production" unless you created a different one
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API version (date-pinned). Bump only when you intend to adopt newer API behavior.
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
